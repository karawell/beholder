#Express App Port. ex: 3001
PORT=

#JWT Secret Key. Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

#JWT Expiration (in seconds). ex: 1800 (30 min)
JWT_EXPIRES=

#The database name. ex: beholder
DB_NAME=

#The database user. ex: root
DB_USER=

#The user password
DB_PWD=

#The database host. ex: localhost
DB_HOST=

#The database port. ex: 3306 (MySQL)
DB_PORT=

#Show logs at console? ex: false
DB_LOGS=

#The database vendor. ex: mysql, pg, etc
DB_DIALECT=

#The AES 32-bytes key. Gere com: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
AES_KEY=

#The allowed origins. ex: http://localhost:3000 (your front)
CORS_ORIGIN=

#The beholder logs are activated? ex: true
BEHOLDER_LOGS=

#The Beholder interval between automation executions (ms). ex: 0
AUTOMATION_INTERVAL=

#The Agenda logs are activated? ex: true
AGENDA_LOGS=

#Winston log level: error | warn | info | debug (default: info)
LOG_LEVEL=

# =============================================================================
# BINANCE — configurar via Settings na interface, não aqui.
# Os valores abaixo são apenas referência para o seeder padrão.
#
# PRODUÇÃO (Binance real):
#   apiUrl:    https://api.binance.com/api/
#   streamUrl: wss://stream.binance.com:9443/ws/
#
# TESTNET (recomendado para testes — sem dinheiro real):
#   apiUrl:    https://testnet.binance.vision/api/
#   streamUrl: wss://testnet.binance.vision/ws/
#   Criar conta testnet em: https://testnet.binance.vision/
